# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///db.sqlite3
# For PostgreSQL: postgresql://user:password@localhost:5432/catalog_db

# CORS (Frontend domains)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Production (Render/Heroku/etc)
# SECRET_KEY=<generate-strong-random-key>
# DEBUG=False
# ALLOWED_HOSTS=your-app.render.com,www.your-app.com
# CORS_ALLOWED_ORIGINS=https://your-frontend.com,https://www.your-frontend.com

